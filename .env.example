# ─── Base de datos ───────────────────────────────────────────────
DATABASE_URL=postgresql://iccu:PASSWORD@postgres:5432/iccu_th

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=cambiar_en_produccion
JWT_EXPIRES_IN=8h

# ─── Contraseñas de los usuarios del panel (hashes bcrypt) ───────
# Los usuarios, sus roles y las provincias que tiene asignada cada uno se
# definen en backend/src/auth/users.config.ts. Aquí solo van los hashes.
#
# Generar un hash:
#   node -e "require('bcrypt').hash('tu_password',10).then(console.log)"
#
# Escapar cada '$' como '$$': docker-compose interpola estas variables antes
# de pasarlas al contenedor y se comería los '$' del hash.
ADMIN_PASSWORD_HASH=       # superadmin: todas las provincias + Ausentismo
SST_PASSWORD_HASH=         # operador
BIENESTAR_PASSWORD_HASH=   # operador

# ─── WHO ICD API (CIE-10) — Registro en icdaccessmanagement.who.int ──
WHO_ICD_CLIENT_ID=
WHO_ICD_CLIENT_SECRET=

# ─── Cloudinary ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Frontend ────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api

# ─── Puertos ─────────────────────────────────────────────────────
BACKEND_PORT=5000
FRONTEND_PORT=5555

# ─── PostgreSQL (para docker-compose) ────────────────────────────
DB_PASSWORD=iccu_dev_password
DB_NAME=iccu_th
DB_USER=iccu
